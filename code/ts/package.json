  },
  "bugs": {
    "url": "https://github.com/macss-dev/service_client/issues"
  },
  "homepage": "https://github.com/macss-dev/service_client/tree/main/code/ts#readme",
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.19.11",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
